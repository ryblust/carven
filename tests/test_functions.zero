fn add_without_any_type(a, b) {
    return a + b;
}

// auto add_without_any_type(auto a, auto b) noexcept {
//     return a + b;
// }

fn add_with_only_parameter_type(a: i32, b: i32) {
    return a + b;
}

// auto add_with_only_parameter_type(std::int32_t a, std::int32_t b) {
//     return a + b;
// }

fn add_with_all_type(a: i32, b: i32) -> i32 {
    return a + b;
}

// auto add_with_all_type(std::int32_t a, std::int32_t b) noexcept -> std::int32_t {
//     return a + b;
// }

fn main() {
    let a = add_without_any_type(1, 2);
    let b = add_with_only_parameter_type(3, 4);
    let c = add_with_all_type(5, 6);

    return a == 3 && b == 7 && c == 11;
}