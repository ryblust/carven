import std;

fn classify(value) {
    return match value {
        i32 => { "int" }
        f64 => { "float" }
        _ => { "other" }
    };
}

fn main() {
    let result = match 2 {
        1 => { "one" }
        2 => { "two" }
        _ => { "other" }
    };
    std::println("{} {}", result, classify(42));
}
