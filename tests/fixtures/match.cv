import std;

fn print_type(value) {
    match value {
        i32 => { std::println("int"); }
        f64 => { std::println("float"); }
        _ => { std::println("other"); }
    }
}

fn print_mixed(v) {
    match v {
        0 => { std::println("zero"); }
        i32 => { std::println("int"); }
        _ => { std::println("other"); }
    }
}

fn main() {
    let result = match 2 {
        1 => { "one" }
        2 => { "two" }
        _ => { "other" }
    };
    std::println("{}", result);
    print_type(42);
    print_mixed(0);
    print_mixed(42);
}
